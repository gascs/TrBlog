APP_NAME=TrBlog
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 数据库配置
# 支持: mysql, pgsql, sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trblog
DB_USERNAME=root
DB_PASSWORD=root

# PostgreSQL 配置
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=trblog
# DB_USERNAME=trblog
# DB_PASSWORD=trblog123

# SQLite 配置
# DB_CONNECTION=sqlite
# DB_DATABASE=${DB_DATABASE:-database/database.sqlite}

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 邮件配置
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#  Sanctum 配置
SANCTUM_STATEFUL_DOMAINS=localhost:8000
SESSION_DOMAIN=localhost